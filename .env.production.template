# =============================================================
# ManagedAd — Production Environment Variables
# =============================================================
# Copy to Vercel Environment Variables (or .env.production.local)
# Fill in ALL values before deploying
# =============================================================

# Database (Cloud PostgreSQL — Neon recommended)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://www.managedad.com"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Google OAuth (for NextAuth social login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""

# Meta (Facebook) Ads API
META_APP_ID=""
META_APP_SECRET=""

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=""

# Razorpay (payment gateway)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# Plan IDs from Razorpay dashboard
RAZORPAY_STARTER_MONTHLY_PLAN_ID=""
RAZORPAY_STARTER_ANNUAL_PLAN_ID=""
RAZORPAY_GROWTH_MONTHLY_PLAN_ID=""
RAZORPAY_GROWTH_ANNUAL_PLAN_ID=""
RAZORPAY_AGENCY_MONTHLY_PLAN_ID=""
RAZORPAY_AGENCY_ANNUAL_PLAN_ID=""

# SMTP (email)
SMTP_HOST="smtp.pabbly.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ManagedAd <noreply@managedad.com>"

# WhatsApp Cloud API (Growth/Agency plan notifications)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# Vercel Cron secret — authenticates /api/cron/* routes
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# Encryption key for stored OAuth tokens (32 bytes hex)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=""

# App
NEXT_PUBLIC_APP_URL="https://www.managedad.com"
NODE_ENV="production"
