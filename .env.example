# Database
DATABASE_URL="postgresql://user:password@localhost:5432/performancex?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Google OAuth (for NextAuth login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""

# Meta (Facebook) Ads API
META_APP_ID=""
META_APP_SECRET=""

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=""

# Razorpay (payment gateway)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# Plan IDs from Razorpay dashboard (required for subscription billing)
RAZORPAY_STARTER_MONTHLY_PLAN_ID=""
RAZORPAY_STARTER_ANNUAL_PLAN_ID=""
RAZORPAY_GROWTH_MONTHLY_PLAN_ID=""
RAZORPAY_GROWTH_ANNUAL_PLAN_ID=""
RAZORPAY_AGENCY_MONTHLY_PLAN_ID=""
RAZORPAY_AGENCY_ANNUAL_PLAN_ID=""

# SMTP (Pabbly Email Marketing or any SMTP provider)
SMTP_HOST="smtp.pabbly.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ManagedAd <noreply@managedad.io>"

# WhatsApp Cloud API (Meta Business — for Growth/Agency alert notifications)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# Vercel Cron secret — used to authenticate /api/cron/* routes
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# Encryption key for stored OAuth tokens (32 bytes hex)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
